# ==============================================================================
# Invariable Docs - Configuration Settings
# Copy this file to .env before running the application: cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. PROVIDER SELECTION (Plug & Play Strategy)
# Options for LLM_PROVIDER: "ollama", "openai", "anthropic", "litellm"
LLM_PROVIDER="ollama"

# Options for EMBEDDING_PROVIDER: "local_bge", "openai", "cohere"
EMBEDDING_PROVIDER="local_bge"

# Options for RERANKER_PROVIDER: "local_bge", "cohere", "jina", "none"
RERANKER_PROVIDER="local_bge"

# Options for VECTOR_STORE_PROVIDER: "qdrant_local", "qdrant_cloud", "pinecone"
VECTOR_STORE_PROVIDER="qdrant_local"

# Options for OBSERVABILITY_PROVIDER: "local_logging", "langfuse_selfhosted", "langfuse_cloud"
OBSERVABILITY_PROVIDER="local_logging"

# ------------------------------------------------------------------------------
# 2. V1 LOCAL PROVIDER SETTINGS (MacBook Air M5 Optimization)
# ------------------------------------------------------------------------------
# Ollama settings (runs via Metal API on Apple Silicon)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b-instruct-q4_K_M"
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.90

# Local Embedding settings (runs via Apple MPS / sentence-transformers)
LOCAL_EMBEDDING_MODEL="BAAI/bge-large-en-v1.5"
LOCAL_EMBEDDING_DIMENSION=1024
LOCAL_EMBEDDING_DEVICE="mps"

# Local Re-Ranker settings
LOCAL_RERANKER_MODEL="BAAI/bge-reranker-v2-m3"
LOCAL_RERANKER_DEVICE="mps"
RERANKER_TOP_N=4
RERANKER_SCORE_THRESHOLD=0.25

# Qdrant Local settings
QDRANT_LOCAL_PATH="./qdrant_storage"
QDRANT_COLLECTION_NAME="invariable_docs_v1"

# ------------------------------------------------------------------------------
# 3. HYBRID SEARCH & CHUNKING CONFIGURATION
# ------------------------------------------------------------------------------
# Chunking parameters
CHUNKING_STRATEGY="recursive"  # Options: "recursive", "semantic"
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_SIZE=50
SEMANTIC_CHUNK_THRESHOLD=0.55

# Retrieval parameters
RETRIEVAL_TOP_K=15
RRF_K=60
HYBRID_DENSE_WEIGHT=0.7
HYBRID_SPARSE_WEIGHT=0.3
BM25_K1=1.2
BM25_B=0.75

# ------------------------------------------------------------------------------
# 4. CLOUD & ENTERPRISE API KEYS (Only required if using cloud providers)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

COHERE_API_KEY=""
COHERE_RERANK_MODEL="rerank-v3.5"

QDRANT_CLOUD_URL=""
QDRANT_CLOUD_API_KEY=""

PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=""
PINECONE_INDEX_NAME=""

LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"
